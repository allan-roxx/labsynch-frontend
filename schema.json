components:
  schemas:
    AccountStatusEnum:
      enum:
      - ACTIVE
      - SUSPENDED
      - BLOCKED
      type: string
      description: |-
        * `ACTIVE` - Active
        * `SUSPENDED` - Suspended
        * `BLOCKED` - Blocked
    ActionEnum:
      enum:
      - CREATE
      - UPDATE
      - DELETE
      - LOGIN
      - LOGOUT
      - CANCEL
      - APPROVE
      - DISPATCH
      - ISSUE
      - RETURN
      - COMPLETE
      - PAYMENT
      - RESOLVE
      type: string
      description: |-
        * `CREATE` - Create
        * `UPDATE` - Update
        * `DELETE` - Delete
        * `LOGIN` - Login
        * `LOGOUT` - Logout
        * `CANCEL` - Cancel
        * `APPROVE` - Approve
        * `DISPATCH` - Dispatch
        * `ISSUE` - Issue
        * `RETURN` - Return
        * `COMPLETE` - Complete
        * `PAYMENT` - Payment
        * `RESOLVE` - Resolve
    AdminSchoolProfileUpdate:
      type: object
      description: For ADMIN updating a school â€” includes status and financial fields.
      properties:
        school_name:
          type: string
          maxLength: 255
        registration_number:
          type: string
          maxLength: 100
        physical_address:
          type: string
        county:
          type: string
          maxLength: 100
        town:
          type: string
          description: Town or locality of the school.
          maxLength: 100
        gps_latitude:
          type: string
          format: decimal
          pattern: ^-?\d{0,3}(?:\.\d{0,6})?$
          nullable: true
        gps_longitude:
          type: string
          format: decimal
          pattern: ^-?\d{0,3}(?:\.\d{0,6})?$
          nullable: true
        transport_zone:
          type: string
          format: uuid
          nullable: true
          description: The transport zone used to calculate delivery fees.
        contact_person:
          type: string
          maxLength: 255
        contact_designation:
          type: string
          maxLength: 255
        credit_limit:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        account_status:
          $ref: '#/components/schemas/AccountStatusEnum'
      required:
      - school_name
    AuditLog:
      type: object
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        actor:
          type: string
          format: uuid
          readOnly: true
          nullable: true
          description: User who performed the action. Null for system-triggered actions.
        actor_email:
          type: string
          format: email
          readOnly: true
        action:
          allOf:
          - $ref: '#/components/schemas/ActionEnum'
          readOnly: true
        app_label:
          type: string
          readOnly: true
        model_name:
          type: string
          readOnly: true
        object_id:
          type: string
          readOnly: true
          description: Primary key (UUID) of the affected record.
        object_repr:
          type: string
          readOnly: true
          description: Human-readable string representation of the affected record
            at the time of the action.
        changes:
          readOnly: true
          nullable: true
          description: Dict describing what changed. Keys are field names; values
            are [old, new] pairs.
        ip_address:
          type: string
          readOnly: true
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - action
      - actor
      - actor_email
      - app_label
      - changes
      - created_at
      - id
      - ip_address
      - model_name
      - object_id
      - object_repr
    BookingCreate:
      type: object
      description: Validates incoming booking requests.
      properties:
        pickup_date:
          type: string
          format: date
        return_date:
          type: string
          format: date
        special_instructions:
          type: string
          default: ''
        requires_transport:
          type: boolean
          default: false
        items:
          type: array
          items:
            $ref: '#/components/schemas/BookingItemCreate'
      required:
      - items
      - pickup_date
      - return_date
    BookingItemCreate:
      type: object
      description: Validates individual items within a booking request.
      properties:
        equipment:
          type: string
          format: uuid
        quantity:
          type: integer
          minimum: 1
      required:
      - equipment
      - quantity
    BookingItemRead:
      type: object
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        equipment:
          allOf:
          - $ref: '#/components/schemas/EquipmentRead'
