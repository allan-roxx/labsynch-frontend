openapi: 3.0.3
info:
  title: LabSynch API
  version: 2.0.0
  description: Laboratory Equipment Rental and Management Platform API
paths:
  /api/audit-logs/:
    get:
      operationId: audit_logs_list
      description: |-
        Read-only endpoint for browsing the audit log.
        Restricted to ADMIN users only.
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - audit-logs
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedAuditLogList'
          description: ''
  /api/audit-logs/{id}/:
    get:
      operationId: audit_logs_retrieve
      description: |-
        Read-only endpoint for browsing the audit log.
        Restricted to ADMIN users only.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Audit Log.
        required: true
      tags:
      - audit-logs
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AuditLog'
          description: ''
  /api/auth/login/:
    post:
      operationId: auth_login_create
      description: |-
        POST /api/auth/login/

        Authenticate a user and return JWT tokens.
      summary: Login â€” returns access + refresh JWT tokens plus user data
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Login'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Login'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Login'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserResponse'
          description: ''
  /api/auth/logout/:
    post:
      operationId: auth_logout_create
      description: |-
        POST /api/auth/logout/

        Blacklist the refresh token to log the user out.
      summary: Logout â€” blacklists the refresh token
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Logout'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Logout'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Logout'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          description: Logged out successfully.
  /api/auth/password-reset/:
    post:
      operationId: auth_password_reset_create
      description: |-
        POST /api/auth/password-reset/

        Send a password reset email. Always returns 200 for security.
      summary: Request password reset email
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PasswordResetRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PasswordResetRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PasswordResetRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: Reset email sent if account exists.
  /api/auth/password-reset-confirm/:
    post:
      operationId: auth_password_reset_confirm_create
      description: |-
        POST /api/auth/password-reset-confirm/

        Reset the user's password using the uid + token from the reset email.
      summary: Confirm password reset with uid + token
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PasswordResetConfirm'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PasswordResetConfirm'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PasswordResetConfirm'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: Password reset successfully.
  /api/auth/register/:
    post:
      operationId: auth_register_create
      description: |-
        POST /api/auth/register/

        Register a new SCHOOL user. Creates User + SchoolProfile.
      summary: Register a new school account
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Register'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Register'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Register'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserResponse'
          description: ''
  /api/auth/token/refresh/:
    post:
      operationId: auth_token_refresh_create
      description: |-
        Takes a refresh type JSON web token and returns an access type JSON web
        token if the refresh token is valid.
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenRefresh'
          description: ''
  /api/auth/verify-email/:
    post:
      operationId: auth_verify_email_create
      description: |-
        POST /api/auth/verify-email/

        Verify a user's email address using the uid + token from the verification link.
      summary: Verify email address
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/EmailVerification'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/EmailVerification'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/EmailVerification'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserResponse'
          description: ''
  /api/bookings/:
    get:
      operationId: bookings_list
      description: |-
        CRUD API for Bookings.
        SCHOOL users can see/create/cancel their own bookings.
        ADMIN users can see all and manage statuses.
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - bookings
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedBookingReadList'
          description: ''
    post:
      operationId: bookings_create
      description: |-
        CRUD API for Bookings.
        SCHOOL users can see/create/cancel their own bookings.
        ADMIN users can see all and manage statuses.
      tags:
      - bookings
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BookingCreate'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/BookingCreate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/BookingCreate'
        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BookingCreate'
          description: ''
  /api/bookings/{id}/:
    get:
      operationId: bookings_retrieve
      description: |-
        CRUD API for Bookings.
        SCHOOL users can see/create/cancel their own bookings.
        ADMIN users can see all and manage statuses.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Booking.
        required: true
      tags:
      - bookings
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BookingRead'
          description: ''
    put:
      operationId: bookings_update
      description: Only ADMIN users can update bookings arbitrarily.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Booking.
        required: true
      tags:
      - bookings
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BookingRead'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/BookingRead'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/BookingRead'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BookingRead'
          description: ''
    patch:
      operationId: bookings_partial_update
      description: |-
        CRUD API for Bookings.
        SCHOOL users can see/create/cancel their own bookings.
        ADMIN users can see all and manage statuses.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Booking.
        required: true
      tags:
      - bookings
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedBookingRead'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedBookingRead'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedBookingRead'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BookingRead'
          description: ''
    delete:
      operationId: bookings_destroy
      description: |-
        CRUD API for Bookings.
        SCHOOL users can see/create/cancel their own bookings.
        ADMIN users can see all and manage statuses.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Booking.
        required: true
      tags:
      - bookings
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/bookings/{id}/approve/:
    post:
      operationId: bookings_approve_create
      description: Admin approves a PENDING booking -> APPROVED.
      summary: Approve a PENDING booking (admin only)
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Booking.
        required: true
      tags:
      - bookings
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BookingRead'
          description: ''
  /api/bookings/{id}/cancel/:
    post:
      operationId: bookings_cancel_create
      description: Cancel a PENDING/APPROVED/RESERVED booking.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Booking.
        required: true
      tags:
      - bookings
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BookingRead'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/BookingRead'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/BookingRead'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BookingRead'
          description: ''
  /api/bookings/{id}/complete/:
    post:
      operationId: bookings_complete_create
      description: Admin marks a RETURNED booking as COMPLETED.
      summary: Complete a RETURNED booking (admin only)
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Booking.
        required: true
      tags:
      - bookings
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BookingRead'
          description: ''
  /api/bookings/{id}/contract/:
    get:
      operationId: bookings_contract_retrieve
      description: Download a PDF equipment usage agreement for a booking.
      summary: Download equipment usage agreement PDF
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Booking.
        required: true
      tags:
      - bookings
      security:
      - jwtAuth: []
      responses:
        '200':
          description: PDF contract file
  /api/cart/:
    get:
      operationId: cart_retrieve
      description: |-
        GET  /api/cart/         â€” retrieve the current user's cart
        PATCH /api/cart/        â€” set pickup_date / return_date / special_instructions
        DELETE /api/cart/       â€” clear all items + reset dates
      summary: Get current cart
      tags:
      - cart
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CartRead'
          description: ''
    patch:
      operationId: cart_partial_update
      description: |-
        GET  /api/cart/         â€” retrieve the current user's cart
        PATCH /api/cart/        â€” set pickup_date / return_date / special_instructions
        DELETE /api/cart/       â€” clear all items + reset dates
      summary: Set cart dates / instructions
      tags:
      - cart
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedCartDates'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedCartDates'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedCartDates'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CartRead'
          description: ''
    delete:
      operationId: cart_destroy
      description: |-
        GET  /api/cart/         â€” retrieve the current user's cart
        PATCH /api/cart/        â€” set pickup_date / return_date / special_instructions
        DELETE /api/cart/       â€” clear all items + reset dates
      summary: Clear cart
      tags:
      - cart
      security:
      - jwtAuth: []
      responses:
        '200':
          description: Cart cleared.
  /api/cart/checkout/:
    post:
      operationId: cart_checkout_create
      description: |-
        POST /api/cart/checkout/
        Converts the cart into a Booking (status=PENDING) and clears the cart.
      summary: Checkout cart â€” creates a Booking from cart contents
      tags:
      - cart
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BookingRead'
          description: ''
  /api/cart/items/:
    post:
      operationId: cart_items_create
      description: |-
        POST /api/cart/items/
        Add a new equipment item to the cart, or update its quantity if already present.
      summary: Add item to cart (or update quantity if already present)
      tags:
      - cart
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CartItemWrite'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CartItemWrite'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CartItemWrite'
        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CartItemRead'
          description: ''
  /api/cart/items/{item_id}/:
    patch:
      operationId: cart_items_partial_update
      description: |-
        PATCH  /api/cart/items/<item_id>/  â€” update quantity
        DELETE /api/cart/items/<item_id>/  â€” remove item
      summary: Update cart item quantity
      parameters:
      - in: path
        name: item_id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - cart
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedCartItemUpdate'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedCartItemUpdate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedCartItemUpdate'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CartItemRead'
          description: ''
    delete:
      operationId: cart_items_destroy
      description: |-
        PATCH  /api/cart/items/<item_id>/  â€” update quantity
        DELETE /api/cart/items/<item_id>/  â€” remove item
      summary: Remove item from cart
      parameters:
      - in: path
        name: item_id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - cart
      security:
      - jwtAuth: []
      responses:
        '200':
          description: Item removed.
  /api/damages/:
    get:
      operationId: damages_list
      description: |-
        CRUD for Damage Reports.
        Strictly restricted to ADMIN users.
      summary: List all damage reports
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - damages
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedDamageReportReadList'
          description: ''
    post:
      operationId: damages_create
      description: |-
        CRUD for Damage Reports.
        Strictly restricted to ADMIN users.
      summary: Create damage report
      tags:
      - damages
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/DamageReportCreate'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/DamageReportCreate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/DamageReportCreate'
        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DamageReportRead'
          description: ''
  /api/damages/{id}/:
    get:
      operationId: damages_retrieve
      description: |-
        CRUD for Damage Reports.
        Strictly restricted to ADMIN users.
      summary: Get a damage report
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Damage Report.
        required: true
      tags:
      - damages
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DamageReportRead'
          description: ''
    put:
      operationId: damages_update
      description: |-
        CRUD for Damage Reports.
        Strictly restricted to ADMIN users.
      summary: Update damage report
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Damage Report.
        required: true
      tags:
      - damages
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/DamageReportCreate'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/DamageReportCreate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/DamageReportCreate'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DamageReportRead'
          description: ''
    patch:
      operationId: damages_partial_update
      description: |-
        CRUD for Damage Reports.
        Strictly restricted to ADMIN users.
      summary: Partial update damage report
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Damage Report.
        required: true
      tags:
      - damages
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedDamageReportCreate'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedDamageReportCreate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedDamageReportCreate'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DamageReportRead'
          description: ''
    delete:
      operationId: damages_destroy
      description: |-
        CRUD for Damage Reports.
        Strictly restricted to ADMIN users.
      summary: Delete damage report
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Damage Report.
        required: true
      tags:
      - damages
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/damages/{id}/resolve/:
    post:
      operationId: damages_resolve_create
      description: |-
        CRUD for Damage Reports.
        Strictly restricted to ADMIN users.
      summary: Resolve a damage report (set resolution status + repair cost)
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this Damage Report.
        required: true
      tags:
      - damages
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/DamageReportResolve'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/DamageReportResolve'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/DamageReportResolve'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DamageReportRead'
          description: ''
  /api/equipment/:
    get:
      operationId: equipment_list
      description: |-
        CRUD API for Equipment.
        SCHOOL users can read active items, ADMIN users can write and see all.
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
